{
  "name": "at-strategy",
  "version": "1.0.0",
  "description": "AT Strategy sci-fi RTS beta built with Three.js, Vite, and Electron.",
  "author": "Ataher-KoW",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && electron .\"",
    "build": "vite build",
    "preview": "vite preview",
    "logo": "node scripts/generate-logo.mjs",
    "setup": "node scripts/setup-assets.mjs",
    "server": "node server/at-strategy-server.mjs",
    "test:v0.2": "node scripts/smoke-v0.2.mjs",
    "test:v0.3": "node scripts/smoke-v0.3.mjs",
    "test:v1": "node scripts/smoke-v1.mjs",
    "test:packaged": "node scripts/smoke-packaged.mjs",
    "pack": "npm run logo && npm run build && electron-builder --dir",
    "dist": "npm run logo && npm run build && electron-builder",
    "dist:portable": "npm run logo && npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "three": "^0.181.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "vite": "^7.2.6",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.ataherkow.atstrategy",
    "productName": "AT Strategy",
    "asar": true,
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "package.json"
    ],
    "win": {
      "icon": "icon.ico",
      "target": [
        "nsis",
        "portable"
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AT Strategy"
    }
  }
}
